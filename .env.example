# Copy this file to ".env" and fill in your own values.
# ".env" is git-ignored — never commit real keys.

# ── Azure Speech (required for narration) ───────────────────────────────────
# Create a free "Speech" resource in the Azure Portal, then copy KEY 1 and the
# resource Region from the resource's "Keys and Endpoint" page.
#   https://portal.azure.com  ->  Create resource  ->  Speech
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
